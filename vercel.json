{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/robots.txt", "destination": "/api/robots" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/feed/meta.xml", "destination": "/api/feed?format=meta" },
    { "source": "/feed/google.xml", "destination": "/api/feed?format=google" },
    { "source": "/feed/tiktok.csv", "destination": "/api/feed?format=tiktok" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
